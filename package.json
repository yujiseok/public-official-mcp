{
  "name": "public-official-mcp-server",
  "version": "1.1.0",
  "description": "MCP server for Korean public official asset disclosure data (공직자 재산공개)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "public-official-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "korea",
    "public-official",
    "asset-disclosure",
    "공직자",
    "재산공개"
  ],
  "author": "Jiseok Yu (https://github.com/yujiseok)",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "mcpName": "io.github.yujiseok/public-official-mcp-server",
  "homepage": "https://github.com/yujiseok/public-official-mcp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/yujiseok/public-official-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.2"
  }
}
